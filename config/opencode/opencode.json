{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth"],
  "permission": {
    "bash": "ask",
    "write": "ask",
    "edit": "ask",
    "task": "ask",
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": ["npx", "-y", "tavily-mcp"],
      "enabled": true
    }
  }
}
